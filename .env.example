# Número do WhatsApp que recebe os pedidos, com código do país e DDD, só números
# Exemplo: 55 42 9 9903-9243 -> 5542999039243
NEXT_PUBLIC_WHATSAPP_NUMERO=5542999039243

# Usuário do painel admin
ADMIN_USER=admin

# Hash da senha do admin — gere com: npm run hash-password -- suasenha
# Se for testar num arquivo .env.local, coloque \$ no lugar de $ (ex: \$2b\$10\$...),
# senão o Next.js tenta interpretar o $ como variável. Na Vercel não precisa escapar.
ADMIN_PASSWORD_HASH=

# Segredo usado para assinar o token de login (qualquer texto longo e aleatório)
JWT_SECRET=troque-por-um-texto-aleatorio-bem-grande

# Preenchido automaticamente pela Vercel ao criar um Blob Store no projeto.
# Sem essa variável, o site guarda produtos/imagens localmente em ./data e ./public/uploads (só para testes locais).
BLOB_READ_WRITE_TOKEN=
